# Copy to .env and adjust as needed
DATABASE_URL=postgres://piramida:piramida@localhost:5432/piramida
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=info
# Comma-separated CORS allowlist; unset = allow any origin (dev only)
ALLOWED_ORIGINS=http://localhost:3000
# Shared secret for the /admin page; admin API is disabled when unset
ADMIN_TOKEN=change-me
# Frontend calls the API through the nginx reverse proxy
VITE_API_URL=http://localhost:8080
# Absolute public URL of the web app (og:image, JSON-LD); set the real domain in production
VITE_SITE_URL=http://localhost:8080
# JWT signing secret for optional client accounts; auth is disabled when unset
JWT_SECRET=change-me-long-random
